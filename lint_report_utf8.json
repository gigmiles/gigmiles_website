opacity-100'}`}>\r\n                                <div className=\"flex items-center justify-between mb-4\">\r\n                                    <label className=\"text-sm font-medium text-slate-400 block\">Depreciation & Wear ($/mile)</label>\r\n                                    {ownershipType !== 'owned' && (\r\n                                        <span className=\"text-[10px] font-bold text-emerald-500 bg-emerald-500/10 px-2 py-0.5 rounded-full\">Not Applicable for Rentals</span>\r\n                                    )}\r\n                                </div>\r\n                                <div className=\"space-y-6\">\r\n                                    <Input\r\n                                        type=\"number\"\r\n                                        step=\"0.001\"\r\n                                        value={depreciationRate}\r\n                                        onChange={(e) => setDepreciationRate(parseFloat(e.target.value.replace(',', '.')) || 0)}\r\n                                        className=\"h-12 bg-white/5 border-white/10 rounded-xl\"\r\n                                    />\r\n                                    <DepreciationCalculator onRateChange={setDepreciationRate} />\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div className=\"pt-6\">\r\n                            <Button\r\n                                type=\"submit\"\r\n                                disabled={isLoading || !model}\r\n                                className=\"w-full h-14 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-2xl shadow-xl shadow-emerald-500/20 active:scale-[0.98] transition-all\"\r\n                            >\r\n                                {isLoading ? <Loader2 className=\"size-5 animate-spin mr-2\" /> : <Save className=\"size-5 mr-2\" />}\r\n                                {editingVehicle ? 'Update Vehicle' : 'Save New Vehicle'}\r\n                            </Button>\r\n                        </div>\r\n                    </form>\r\n                </SheetContent>\r\n            </Sheet>\r\n        </div>\r\n    )\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\app\\dashboard\\settings\\vehicle\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\app\\dashboard\\tax\\actions.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\app\\dashboard\\tax\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowUpCircle' is defined but never used.","line":11,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":18,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowUpCircle"},"fix":{"range":[450,470],"text":""},"desc":"Remove unused variable \"ArrowUpCircle\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { getTaxOverview, addTaxPayment } from './actions'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Input } from '@/components/ui/input'\r\nimport { redirect } from 'next/navigation'\r\nimport { revalidatePath } from 'next/cache'\r\nimport { IRS_STANDARD_MILEAGE_RATE_2025 } from '@/utils/calculations'\r\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription } from \"@/components/ui/card\"\r\nimport {\r\n    ShieldCheck,\r\n    Clock,\r\n    ArrowUpCircle,\r\n    AlertCircle,\r\n    Calendar,\r\n    DollarSign\r\n} from 'lucide-react'\r\n\r\nexport default async function TaxPage() {\r\n    const quarters = await getTaxOverview()\r\n    if (!quarters) redirect('/login')\r\n\r\n    const totalEstimated = quarters.reduce((acc, q) => acc + q.estimatedTax, 0)\r\n    const totalPaid = quarters.reduce((acc, q) => acc + q.paid, 0)\r\n    const totalDue = totalEstimated - totalPaid\r\n\r\n    async function handlePayment(formData: FormData) {\r\n        'use server'\r\n        const quarter = parseInt(formData.get('quarter') as string)\r\n        const amount = parseFloat(formData.get('amount') as string)\r\n\r\n        if (quarter && amount) {\r\n            await addTaxPayment(quarter, amount)\r\n            revalidatePath('/dashboard/tax')\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-10 animate-fade-in\">\r\n            {/* Header */}\r\n            <div>\r\n                <h1 className=\"font-display text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-50\">Tax Center (2025)</h1>\r\n                <p className=\"mt-2 text-muted-foreground\">Manage your quarterly estimated taxes and track your payment history.</p>\r\n            </div>\r\n\r\n            {/* Yearly Financial Summary */}\r\n            <div className=\"grid gap-6 md:grid-cols-3\">\r\n                <Card className=\"border-none shadow-premium bg-slate-900 text-white overflow-hidden\">\r\n                    <CardHeader className=\"pb-2\">\r\n                        <CardTitle className=\"text-sm font-medium text-slate-400 uppercase tracking-wider\">Total Estimated Tax</CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent>\r\n                        <div className=\"text-3xl font-bold font-display\">${totalEstimated.toFixed(2)}</div>\r\n                        <p className=\"text-xs text-slate-500 mt-2 italic\">Based on log history</p>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                <Card className=\"border-none shadow-premium bg-emerald-600 text-white\">\r\n                    <CardHeader className=\"pb-2\">\r\n                        <CardTitle className=\"text-sm font-medium text-emerald-100 uppercase tracking-wider text-opacity-80\">Total Payments</CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent>\r\n                        <div className=\"text-3xl font-bold font-display\">${totalPaid.toFixed(2)}</div>\r\n                        <div className=\"mt-2 flex items-center gap-1 text-[10px] text-emerald-100/70\">\r\n                            <ShieldCheck className=\"size-3\" />\r\n                            <span>Verified payments</span>\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                <Card className=\"border-border/50 bg-white dark:bg-slate-900/50 shadow-premium\">\r\n                    <CardHeader className=\"pb-2\">\r\n                        <CardTitle className=\"text-sm font-medium text-muted-foreground uppercase tracking-wider\">Remaining Balance</CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent>\r\n                        <div className={`text-3xl font-bold font-display ${totalDue > 0 ? 'text-ruby-600' : 'text-emerald-600'}`}>\r\n                            ${Math.max(0, totalDue).toFixed(2)}\r\n                        </div>\r\n                        <p className=\"text-xs text-muted-foreground mt-2\">Due by year-end</p>\r\n                    </CardContent>\r\n                </Card>\r\n            </div>\r\n\r\n            {/* Quarterly Timeline */}\r\n            <div className=\"space-y-6\">\r\n                <div className=\"flex items-center gap-2\">\r\n                    <Calendar className=\"size-5 text-slate-400\" />\r\n                    <h2 className=\"text-xl font-bold text-slate-800 dark:text-slate-200\">Quarterly Breakdown</h2>\r\n                </div>\r\n\r\n                <div className=\"grid gap-6 md:grid-cols-2 lg:grid-cols-4\">\r\n                    {quarters.map((q) => (\r\n                        <Card\r\n                            key={q.id}\r\n                            className={`group border-border/50 transition-all hover:shadow-lg ${q.isCurrent ? 'ring-2 ring-emerald-500 ring-offset-2' : ''}`}\r\n                        >\r\n                            <CardHeader className=\"pb-4\">\r\n                                <div className=\"flex items-center justify-between\">\r\n                                    <div className=\"space-y-1\">\r\n                                        <CardTitle className=\"text-lg font-bold\">{q.name}</CardTitle>\r\n                                        <CardDescription className=\"text-xs flex items-center gap-1\">\r\n                                            <Clock className=\"size-3\" />\r\n                                            Due {q.due}\r\n                                        </CardDescription>\r\n                                    </div>\r\n                                    {q.isCurrent && (\r\n                                        <span className=\"flex h-6 items-center rounded-full bg-emerald-100 px-2 text-[10px] font-bold text-emerald-700 uppercase tracking-tighter shadow-sm\">\r\n                                            Active\r\n                                        </span>\r\n                                    )}\r\n                                </div>\r\n                            </CardHeader>\r\n                            <CardContent className=\"space-y-4\">\r\n                                <div className=\"space-y-2\">\r\n                                    <div className=\"flex justify-between text-sm\">\r\n                                        <span className=\"text-muted-foreground\">Estimated</span>\r\n                                        <span className=\"font-semibold text-slate-900 dark:text-slate-100\">${q.estimatedTax.toFixed(2)}</span>\r\n                                    </div>\r\n                                    <div className=\"flex justify-between text-sm\">\r\n                                        <span className=\"text-muted-foreground\">Paid</span>\r\n                                        <span className=\"font-semibold text-emerald-600\">-${q.paid.toFixed(2)}</span>\r\n                                    </div>\r\n                                    <div className=\"pt-3 border-t flex justify-between items-baseline\">\r\n                                        <span className=\"text-xs font-bold uppercase text-slate-400\">Due</span>\r\n                                        <span className={`text-lg font-bold ${q.remaining > 0 ? 'text-amber-600' : 'text-slate-300'}`}>\r\n                                            ${q.remaining.toFixed(2)}\r\n                                        </span>\r\n                                    </div>\r\n                                </div>\r\n\r\n                                <form action={handlePayment} className=\"flex gap-2 pt-2\">\r\n                                    <input type=\"hidden\" name=\"quarter\" value={q.id} />\r\n                                    <div className=\"relative flex-1\">\r\n                                        <DollarSign className=\"absolute left-2.5 top-2.5 size-4 text-slate-400\" />\r\n                                        <Input\r\n                                            name=\"amount\"\r\n                                            type=\"number\"\r\n                                            step=\"0.01\"\r\n                                            placeholder=\"0.00\"\r\n                                            className=\"h-9 pl-8 text-xs rounded-lg\"\r\n                                            min=\"0.01\"\r\n                                            required\r\n                                        />\r\n                                    </div>\r\n                                    <Button type=\"submit\" size=\"sm\" variant=\"secondary\" className=\"h-9 rounded-lg\">\r\n                                        Pay\r\n                                    </Button>\r\n                                </form>\r\n                            </CardContent>\r\n                        </Card>\r\n                    ))}\r\n                </div>\r\n            </div>\r\n\r\n            {/* Disclaimer & Context */}\r\n            <Card className=\"bg-slate-50 dark:bg-slate-900/20 border-border/50\">\r\n                <CardContent className=\"p-4 flex items-start gap-3\">\r\n                    <AlertCircle className=\"size-5 text-blue-500 shrink-0 mt-0.5\" />\r\n                    <div className=\"text-sm text-blue-800 dark:text-blue-300\">\r\n                        <p className=\"font-semibold\">Professional Disclaimer</p>\r\n                        <p className=\"mt-1 opacity-80\">\r\n                            Estimates are calculated using the 2025 Standard Mileage Rate of <strong>${IRS_STANDARD_MILEAGE_RATE_2025.toFixed(2)}/mi</strong>.\r\n                            These values are for tracking purposes only and do not constitute professional tax advice. Always verify with a certified public accountant.\r\n                        </p>\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\app\\dashboard\\types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\app\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\app\\login\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDe