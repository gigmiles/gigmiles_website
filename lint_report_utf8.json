Container' is defined but never used.","line":13,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":13,"endColumn":24,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ResponsiveContainer"},"fix":{"range":[146,172],"text":""},"desc":"Remove unused variable \"ResponsiveContainer\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Cell' is defined but never used.","line":16,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":16,"endColumn":9,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Cell"},"fix":{"range":[197,208],"text":""},"desc":"Remove unused variable \"Cell\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ChartTooltip' is defined but never used.","line":21,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":21,"endColumn":17,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ChartTooltip"},"fix":{"range":[269,288],"text":""},"desc":"Remove unused variable \"ChartTooltip\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ChartLegend' is defined but never used.","line":23,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":23,"endColumn":16,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ChartLegend"},"fix":{"range":[314,332],"text":""},"desc":"Remove unused variable \"ChartLegend\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ChartLegendContent' is defined but never used.","line":24,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":24,"endColumn":23,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ChartLegendContent"},"fix":{"range":[332,357],"text":""},"desc":"Remove unused variable \"ChartLegendContent\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":8,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport {\r\n    AreaChart,\r\n    Area,\r\n    BarChart,\r\n    Bar,\r\n    XAxis,\r\n    YAxis,\r\n    CartesianGrid,\r\n    Tooltip,\r\n    Legend,\r\n    ResponsiveContainer,\r\n    PieChart,\r\n    Pie,\r\n    Cell,\r\n    Label\r\n} from 'recharts'\r\nimport {\r\n    ChartContainer,\r\n    ChartTooltip,\r\n    ChartTooltipContent,\r\n    ChartLegend,\r\n    ChartLegendContent,\r\n    ChartConfig\r\n} from \"@/components/ui/chart\"\r\n\r\ninterface DailyData {\r\n    date: string\r\n    earnings: number\r\n    expenses: number\r\n    netProfit: number\r\n    miles: number\r\n    depreciationCost: number\r\n}\r\n\r\ninterface PlatformData {\r\n    name: string\r\n    value: number\r\n    gross: number\r\n    tips: number\r\n    hours: number\r\n    miles: number\r\n    hourlyRate: number\r\n    tipPct: number\r\n    earningsPerMile: number\r\n    fill?: string\r\n}\r\n\r\ninterface ChartsProps {\r\n    dailyData: DailyData[]\r\n    platformData: PlatformData[]\r\n}\r\n\r\nexport function Charts({ dailyData, platformData }: ChartsProps) {\r\n    const totalGross = platformData.reduce((acc, curr) => acc + curr.gross, 0)\r\n\r\n    const chartConfig: ChartConfig = {\r\n        profit: { label: \"Net Profit\", color: \"hsl(var(--emerald-500))\" },\r\n        gross: { label: \"Gross Revenue\", color: \"hsl(var(--blue-500))\" },\r\n        expenses: { label: \"Expenses\", color: \"hsl(var(--ruby-500))\" }\r\n    }\r\n\r\n    platformData.forEach((plat) => {\r\n        chartConfig[plat.name.toLowerCase().replace(/\\s+/g, '-')] = {\r\n            label: plat.name\r\n        }\r\n    })\r\n\r\n    return (\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-10\">\r\n            {/* Weekly Earnings & Net Profit Analysis */}\r\n            <div className=\"lg:col-span-7 h-[350px] relative\">\r\n                <div className=\"absolute top-0 left-0 flex items-center gap-2 mb-4\">\r\n                    <div className=\"size-2 rounded-full bg-emerald-500\" />\r\n                    <span className=\"text-[10px] font-black uppercase tracking-widest text-slate-500\">Profit Trend</span>\r\n                </div>\r\n                <ChartContainer config={chartConfig} className=\"w-full h-full mt-6\">\r\n                    <AreaChart data={dailyData}>\r\n                        <defs>\r\n                            <linearGradient id=\"colorProfit\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\r\n                                <stop offset=\"5%\" stopColor=\"#10b981\" stopOpacity={0.3} />\r\n                                <stop offset=\"95%\" stopColor=\"#10b981\" stopOpacity={0} />\r\n                            </linearGradient>\r\n                        </defs>\r\n                        <CartesianGrid strokeDasharray=\"3 3\" vertical={false} stroke=\"rgba(255,255,255,0.05)\" />\r\n                        <XAxis\r\n                            dataKey=\"date\"\r\n                            axisLine={false}\r\n                            tickLine={false}\r\n                            tick={{ fontSize: 10, fill: '#64748b' }}\r\n                        />\r\n                        <YAxis\r\n                            axisLine={false}\r\n                            tickLine={false}\r\n                            tick={{ fontSize: 10, fill: '#64748b' }}\r\n                            tickFormatter={(v) => `$${v}`}\r\n                        />\r\n                        <Tooltip\r\n                            content={<ChartTooltipContent />}\r\n                            contentStyle={{ backgroundColor: 'rgba(15, 23, 42, 0.9)', border: 'none', borderRadius: '12px', backdropFilter: 'blur(10px)' }}\r\n                        />\r\n                        <Area\r\n                            type=\"monotone\"\r\n                            dataKey=\"netProfit\"\r\n                            stroke=\"#10b981\"\r\n                            strokeWidth={3}\r\n                            fillOpacity={1}\r\n                            fill=\"url(#colorProfit)\"\r\n                            name=\"Net Profit\"\r\n                        />\r\n                        <Area\r\n                            type=\"monotone\"\r\n                            dataKey=\"earnings\"\r\n                            stroke=\"#3b82f6\"\r\n                            strokeWidth={2}\r\n                            fill=\"transparent\"\r\n                            name=\"Gross\"\r\n                            strokeDasharray=\"5 5\"\r\n                        />\r\n                    </AreaChart>\r\n                </ChartContainer>\r\n            </div>\r\n\r\n            {/* Platform Breakdown Donut Chart */}\r\n            <div className=\"lg:col-span-5 h-[350px] flex flex-col items-center justify-center border-l border-white/5 pl-10\">\r\n                <div className=\"w-full h-full\">\r\n                    <ChartContainer config={chartConfig} className=\"mx-auto aspect-square max-h-[300px]\">\r\n                        <PieChart>\r\n                            <Pie\r\n                                data={platformData}\r\n                                dataKey=\"value\"\r\n                                nameKey=\"name\"\r\n                                innerRadius={75}\r\n                                outerRadius={100}\r\n                                strokeWidth={8}\r\n                                stroke=\"rgba(15, 23, 42, 0.9)\"\r\n                            >\r\n                                <Label\r\n                                    content={({ viewBox }) => {\r\n                                        if (viewBox && \"cx\" in viewBox && \"cy\" in viewBox) {\r\n                                            return (\r\n                                                <text x={viewBox.cx} y={viewBox.cy} textAnchor=\"middle\" dominantBaseline=\"middle\">\r\n                                                    <tspan\r\n                                                        x={viewBox.cx}\r\n                                                        y={viewBox.cy}\r\n                                                        className=\"fill-slate-900 dark:fill-white text-3xl font-display font-bold tracking-tighter\"\r\n                                                    >\r\n                                                        ${totalGross.toLocaleString(undefined, { maximumFractionDigits: 0 })}\r\n                                                    </tspan>\r\n                                                    <tspan\r\n                                                        x={viewBox.cx}\r\n                                                        y={(viewBox.cy || 0) + 24}\r\n                                                        className=\"fill-slate-500 text-[10px] uppercase font-black tracking-widest\"\r\n                                                    >\r\n                                                        Revenue\r\n                                                    </tspan>\r\n                                                </text>\r\n                                            )\r\n                                        }\r\n                                    }}\r\n                                />\r\n                            </Pie>\r\n                            <Tooltip content={<ChartTooltipContent hideLabel />} />\r\n                        </PieChart>\r\n                    </ChartContainer>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\projects\\gigmiles\\src\\components\\reports\\ExpenseBreakdown.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'DollarSign' is defined but never used.","line":5,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":15,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"DollarSign"},"fix":{"range":[64,75],"text":""},"desc":"Remove unused variable 